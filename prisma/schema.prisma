generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id             String        @id
  inviteCode     String?       @unique
  appMode        String        @default("counter")
  periodSettings String        @default("{\"periodLength\": 7, \"cycleLength\": 28}")
  partnerId      String?
  records        DailyRecord[]
  notifications  Notification[]
  pushSubscriptions PushSubscription[]
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model DailyRecord {
  id           String  @id @default(cuid())
  dateKey      String  
  counterValue Int     @default(0)
  status       String?
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
}
