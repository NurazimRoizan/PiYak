generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL")
}

model User {
  id             String        @id
  inviteCode     String?       @unique
  appMode        String        @default("counter")
  periodSettings String        @default("{\"periodLength\": 7, \"cycleLength\": 28}")
  partnerId      String?
  records        DailyRecord[]
}

model DailyRecord {
  id           String  @id @default(cuid())
  dateKey      String  
  counterValue Int     @default(0)
  status       String?
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
}
